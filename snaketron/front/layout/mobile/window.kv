<SnakeTronWindow>:
    orientation: "vertical"

    canvas.before:
        Color:
            rgba: self.app_background_color
        Rectangle:
            pos: self.pos
            size: self.size

    SwipeControlZone:
        orientation: "horizontal"
        size_hint_y: 0.2
        spacing: 5

    ScoreBoard:
        id: score_board
        orientation: "horizontal"
        size_hint_y: 0.05
        spacing: 5

    WorldDisplay:
        id: world_display
        size_hint_y: 0.5

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: 0.05
        spacing: 5

        Button:
            id: button_pause
            text: "Pause"

        Button:
            id: button_toggle_ai_explanations
            text: "Explain AIs"

        Button:
            id: button_toggle_fullspeed
            text: "Full speed"

    SwipeControlZone:
        orientation: "horizontal"
        size_hint_y: 0.2
        spacing: 5
